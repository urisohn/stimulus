r2=stimulus.plot(plot.type='effects',
data=df2, seed=991122,
dv='accepted',stimulus='stim',condition='profile_Skin',
simtot=1000)
r2=stimulus::stimulus.plot(plot.type='effects',
data=df2, seed=991122,
dv='accepted',stimulus='stim',condition='profile_Skin',
simtot=1000)
r1=stimulus::stimulus.plot(plot.type='means',data=df2,
dv='accepted',
stimulus='stim',
condition='profile_Skin')
#File path
fp2 = file.path(other_path,  "/Colada 128 - Stimulus Plots - Effects.svg")
#Start the SVG file
svg(fp2 , width=8,height=5)
#Color for confidence band
col2=adjustcolor('gray',.4)
#Bigger margins
par(mar=c(5.1,6.1,0.5,2.1))
#Plot 1
plot(1:197,r2$observed$effect,ylim=c(-.28,.25),
cex=.5,
xlab='',ylab='',xaxt='n',yaxt='n',pch=16,col='black')
#Line at 0
abline(h=0,lty=2,col='red4')
#Expected
points(1:197,r2$under.null$mean,col='green4',lty=2,lwd=2,type='l')
#Confidence band
polygon(c(1:197, 197:1),                      # x-coordinates, forward then reverse
c(r2$under.null$low, rev(r2$under.null$high)),  # y-coordinates: low then reversed high
col = col2,           # light blue with transparency
border = NA)          # no border
#Y-axis
ys=seq(-.3,.3,.1)
axis(side=2,at=ys,paste0(round(ys*100,0),"%"),las=1)
mtext(side=2,line=4.4,"Effect Size",font=2,cex=1.4)
mtext(side=2,line=3.5,"(Acceptance Rate: Black - White)",font=3,cex=1)
#x-axis
axis(side=1,at=c(1,50,100,150,197),cex=1.25)
mtext(side=1,line=2.4,"Pairs of Black/White Men",font=2,cex=1.4)
mtext(side=1,line=3.4,"(sorted by effect size)",font=3,cex=1)
#Legend
legend('topleft',
pch=c(16,NA,NA),
lty=c(NA,2,1),
lwd=c(NA,3,9),
col=c('black','green4',col2),
bty='n',
legend=c("Observed Effect" ,"Expected under null of homogeneity",
"95% Confidence Band for null)"),
cex=.8,
adj = c(0, 0.5),
inset=.03)
#Text
text(3,min(r2$observed$effect),"Biggest effect",adj=0 ,col='red4',cex=.9)
text(194,max(r2$observed$effect),"Biggest reversal",adj=1,col='red4',cex=.9)
#Explanation
msg <- c(
"EXPLANATION:",
"If the Black-White effect were the same for ALL 197 pairs,",
"we expect *observed* variation across pairs indicated ",
"by green line, and 95% of the 197 estimates within.",
"blue region --> precisely what we see here!")
legend(x = 85, y = -0.1,
legend = msg, cex = 0.7, adj = 0,
bty = "o",         # remove border if undesired, or set to "o" to include
bg = "lightyellow" # background color
)
dev.off()
#Save as .png (for whatsapp and other non-svg outlets)
rsvg::rsvg_png(fp2, paste0(fp2,".png"),width=2400)
#Share of effects that are positive vs negative
mean(r2$observed$effect>=0)
mean(r2$observed$effect<0)
