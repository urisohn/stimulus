f1.path=paste0(other_path,"/Colada 128 - Stimulus Plots - Means.svg")
#Colors
col1='red1'
col2='dodgerblue'
col=ifelse(r1$effect<0,col1,col2)
#Start plot as svg file
svg(f1.path, width=9, height=5.5)
#Margins
par(mar=c(3.1,5.1,0.5,2.1))
#Initiate plot with black markets
plot(r1$profile_Skin_Black,pch=16,ylim=c(-.06,.55),col='black',xlab='',ylab='',xaxt='n',yaxt='n',xlim=c(0,198))
#Add vertical lines, red or blue
segments(x0=1:197, x1=1:197,y0=r1$profile_Skin_Black,y1=r1$profile_Skin_White,col=col,lwd=1.2)
#fill dots
points(r1$profile_Skin_White, pch=21, bg='white', col='black', cex=1)
points(r1$profile_Skin_Black, pch=16, col='black', cex=1)
#Y-axis
ys=seq(0,.5,.1)
axis(side=2,at=ys,paste0(round(ys*100,0),"%"),las=1)
mtext(side=2,line=3.7,"Mean Acceptance Rates",font=2,cex=1.4)
#x-axis
mtext(side=1,line=1,"197 Pairs of Stimuli (photos of a White and a Black man)",font=2,cex=1.4)
#Values labels
xs=c(1,197)
bs=r1$profile_Skin_Black[xs]
ws=r1$profile_Skin_White[xs]
#Size of text
c1=.8
#Four numbers
text(1,bs[1]-.01,paste0(round(bs[1]*100,0),"%"),cex=c1,col=col1,adj=1)
text(1,ws[1]+.01,paste0(round(ws[1]*100,0),"%"),cex=c1,col=col1,adj=1)
text(198,bs[2]+.01,paste0(round(bs[2]*100,0),"%"),cex=c1,col=col2,adj=0)
text(198,ws[2]-.01,paste0(round(ws[2]*100,0),"%"),cex=c1,col=col2,adj=0)
#Paid IDs
polygon(x=c(-10,210,210,-10),y=c(-.1,-.1,0,0),col='gray88')
text(c(1,4),c(-.025,-.05),paste0('#',r1$stim[c(1,2)]),cex=.85,col='purple')
text(c(194,197),c(-.025,-.05),paste0('#',r1$stim[c(196,197)]),cex=.85,col='purple')
text(100, -.0475,"ID of Pairs",col='purple')
arrows(x0=80, x1=15, y0=-.045, y1=-.045, col='purple',length=.05)
arrows(x0=120, x1=185, y0=-.045, y1=-.045, col='purple',length=.05)
#Region labels on the bottom
text(50,.05,"Predicted Effect: White > Black\n65.5% of stimuli",col=col1)
text(175,.05,"Reversals: White < Black\n34.5% of stimuli",col=col2)
#Legend
legend('top',inset=.01,bty='n',pch=c(16,1),c('Black photo','White photo'),title='Acceptance Rate',title.font=2)
dev.off()
